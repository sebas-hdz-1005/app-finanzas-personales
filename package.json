{
  "name": "neon-ledger",
  "version": "1.0.0",
  "private": true,
  "description": "NEON_LEDGER — portal de finanzas personales (Next.js + Firebase).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "firebase:login": "npx -y firebase-tools login",
    "firebase:rules": "npx -y firebase-tools deploy --only firestore:rules,firestore:indexes"
  },
  "dependencies": {
    "firebase": "^10.12.5",
    "next": "^14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.3",
    "@tailwindcss/forms": "^0.5.7",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
